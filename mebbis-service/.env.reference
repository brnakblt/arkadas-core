# MEBBIS Service Environment Variables Reference
# Copy to .env and fill in your values

# Server
PORT=4000
NODE_ENV=production

# MEBBIS Credentials
MEBBIS_USERNAME=your-mebbis-username
MEBBIS_PASSWORD=your-mebbis-password

# Strapi Integration
STRAPI_URL=http://localhost:1337
STRAPI_API_TOKEN=your-strapi-api-token

# Redis
REDIS_URL=redis://localhost:6379

# Browser Automation
HEADLESS=true
BROWSER_TIMEOUT=30000
WEBDAV_PORT=1900

# Logging
LOG_LEVEL=info
