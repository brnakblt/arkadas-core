{
  "kind": "collectionType",
  "collectionName": "kaba_degerlendirmeler",
  "info": {
    "singularName": "kaba-degerlendirme",
    "pluralName": "kaba-degerlendirmeler",
    "displayName": "Kaba Değerlendirme",
    "description": "Kaba Değerlendirme Formu - MEBBIS'ten performans ve ihtiyaçları çeker"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student-profile.student-profile"
    },
    "donem": {
      "type": "string",
      "required": true
    },
    "degerlendirmeTarihi": {
      "type": "date",
      "required": true
    },
    "performanslar": {
      "type": "json",
      "required": true
    },
    "ihtiyaclar": {
      "type": "json",
      "required": true
    },
    "gelisimAlanlari": {
      "type": "json"
    },
    "createdFromMebbis": {
      "type": "boolean",
      "default": false
    },
    "mebbisRefId": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "draft",
        "completed",
        "approved"
      ],
      "default": "draft"
    },
    "notes": {
      "type": "richtext"
    }
  }
}