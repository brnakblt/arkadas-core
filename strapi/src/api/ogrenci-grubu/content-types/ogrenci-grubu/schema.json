{
    "kind": "collectionType",
    "collectionName": "ogrenci_gruplari",
    "info": {
        "singularName": "ogrenci-grubu",
        "pluralName": "ogrenci-gruplari",
        "displayName": "Öğrenci Grubu",
        "description": "Otomatik veya manuel oluşturulan öğrenci grupları"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true
        },
        "groupType": {
            "type": "enumeration",
            "enum": [
                "yas_grubu",
                "seviye_grubu",
                "beceri_alanı",
                "ogretmen_grubu",
                "ozel_grup"
            ],
            "required": true
        },
        "students": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::student-profile.student-profile"
        },
        "primaryTeacher": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "plugin::users-permissions.user"
        },
        "assistantTeachers": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "plugin::users-permissions.user"
        },
        "minAge": {
            "type": "integer"
        },
        "maxAge": {
            "type": "integer"
        },
        "skillLevel": {
            "type": "enumeration",
            "enum": [
                "baslangic",
                "orta",
                "ileri"
            ]
        },
        "focusArea": {
            "type": "enumeration",
            "enum": [
                "ozbakım",
                "akademik",
                "sosyal",
                "motor",
                "dil_iletisim",
                "bilissel",
                "karma"
            ]
        },
        "maxCapacity": {
            "type": "integer",
            "default": 8
        },
        "currentCount": {
            "type": "integer",
            "default": 0
        },
        "isActive": {
            "type": "boolean",
            "default": true
        },
        "autoGenerated": {
            "type": "boolean",
            "default": false
        },
        "schedule": {
            "type": "json",
            "default": []
        },
        "notes": {
            "type": "text"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant"
        }
    }
}