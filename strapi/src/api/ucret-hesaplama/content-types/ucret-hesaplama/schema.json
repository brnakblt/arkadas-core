{
    "kind": "collectionType",
    "collectionName": "ucret_hesaplamalari",
    "info": {
        "singularName": "ucret-hesaplama",
        "pluralName": "ucret-hesaplamalari",
        "displayName": "Ücret Hesaplama",
        "description": "MEB ücret artış formülü hesaplama - ÜFE+TÜFE tabanlı"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "academicYear": {
            "type": "string",
            "required": true
        },
        "effectiveDate": {
            "type": "date",
            "required": true
        },
        "previousYearDecemberUfe": {
            "type": "decimal",
            "required": true
        },
        "previousYearDecemberTufe": {
            "type": "decimal",
            "required": true
        },
        "averageInflation": {
            "type": "decimal"
        },
        "allowedIncreaseRate": {
            "type": "decimal"
        },
        "multiplier": {
            "type": "decimal",
            "default": 1.05
        },
        "basePriceBireysel": {
            "type": "decimal",
            "required": true
        },
        "basePriceGrup": {
            "type": "decimal",
            "required": true
        },
        "newPriceBireysel": {
            "type": "decimal"
        },
        "newPriceGrup": {
            "type": "decimal"
        },
        "mebApprovalDate": {
            "type": "date"
        },
        "mebApprovalNumber": {
            "type": "string"
        },
        "isActive": {
            "type": "boolean",
            "default": true
        },
        "notes": {
            "type": "text"
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant"
        }
    }
}