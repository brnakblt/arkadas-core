{
  "kind": "collectionType",
  "collectionName": "portfolyo_puanlamalari",
  "info": {
    "singularName": "portfolyo-puanlama",
    "pluralName": "portfolyo-puanlamalari",
    "displayName": "Portfolyo Dereceli Puanlama (Ek-7)",
    "description": "Portfolyo dereceli puanlama anahtarı - rubrik değerlendirme"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student-profile.student-profile"
    },
    "academicYear": {
      "type": "string",
      "required": true
    },
    "semester": {
      "type": "enumeration",
      "enum": [
        "guz",
        "bahar"
      ],
      "required": true
    },
    "evaluationDate": {
      "type": "date",
      "required": true
    },
    "evaluator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "organizationScore": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "default": 1
    },
    "organizationNotes": {
      "type": "text"
    },
    "contentQualityScore": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "default": 1
    },
    "contentQualityNotes": {
      "type": "text"
    },
    "progressEvidenceScore": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "default": 1
    },
    "progressEvidenceNotes": {
      "type": "text"
    },
    "varietyScore": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "default": 1
    },
    "varietyNotes": {
      "type": "text"
    },
    "presentationScore": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "default": 1
    },
    "presentationNotes": {
      "type": "text"
    },
    "selfReflectionScore": {
      "type": "integer",
      "min": 1,
      "max": 4,
      "default": 1
    },
    "selfReflectionNotes": {
      "type": "text"
    },
    "totalScore": {
      "type": "integer",
      "min": 6,
      "max": 24
    },
    "overallGrade": {
      "type": "enumeration",
      "enum": [
        "yetersiz",
        "gelisiyor",
        "yeterli",
        "iyi",
        "cok_iyi"
      ]
    },
    "strengths": {
      "type": "text"
    },
    "areasForImprovement": {
      "type": "text"
    },
    "recommendations": {
      "type": "text"
    }
  }
}