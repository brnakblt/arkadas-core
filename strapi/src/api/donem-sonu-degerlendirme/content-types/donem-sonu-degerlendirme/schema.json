{
    "kind": "collectionType",
    "collectionName": "donem_sonu_degerlendirmeleri",
    "info": {
        "singularName": "donem-sonu-degerlendirme",
        "pluralName": "donem-sonu-degerlendirmeleri",
        "displayName": "Dönem Sonu Değerlendirme",
        "description": "Dönem Sonu Değerlendirme Formu - PKT'den otomatik oluşur"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "pkt": {
            "type": "relation",
            "relation": "oneToOne",
            "target": "api::performans-kayit.performans-kayit"
        },
        "student": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::student-profile.student-profile"
        },
        "donem": {
            "type": "string",
            "required": true
        },
        "degerlendirmeTarihi": {
            "type": "date",
            "required": true
        },
        "ulasilanAmaclar": {
            "type": "json"
        },
        "ulasilamayanAmaclar": {
            "type": "json"
        },
        "genelDegerlendirme": {
            "type": "richtext"
        },
        "gelecekDonemOneriler": {
            "type": "richtext"
        },
        "veliGorusleri": {
            "type": "richtext"
        },
        "egitimciGorusleri": {
            "type": "richtext"
        },
        "sonuclar": {
            "type": "json"
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "draft",
                "completed",
                "approved"
            ],
            "default": "draft"
        },
        "mebbisRefId": {
            "type": "string"
        },
        "syncedToMebbis": {
            "type": "boolean",
            "default": false
        },
        "tenant": {
            "type": "relation",
            "relation": "manyToOne",
            "target": "api::tenant.tenant"
        }
    }
}