{
    "kind": "collectionType",
    "collectionName": "personnel",
    "info": {
        "singularName": "personnel",
        "pluralName": "personnel",
        "displayName": "Personnel",
        "description": "Staff and Teacher records"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "fullName": {
            "type": "string",
            "required": true
        },
        "specialty": {
            "type": "string"
        },
        "email": {
            "type": "email",
            "unique": true
        },
        "phone": {
            "type": "string"
        },
        "joinDate": {
            "type": "date"
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "ACTIVE",
                "INACTIVE",
                "ON_LEAVE"
            ],
            "default": "ACTIVE"
        },
        "weeklyHours": {
            "type": "integer",
            "default": 0
        },
        "maxWeeklyHours": {
            "type": "integer",
            "default": 40
        },
        "performanceScore": {
            "type": "integer",
            "min": 0,
            "max": 100
        },
        "avatarUrl": {
            "type": "string"
        }
    }
}