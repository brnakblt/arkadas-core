{
    "kind": "collectionType",
    "collectionName": "students",
    "info": {
        "singularName": "student",
        "pluralName": "students",
        "displayName": "Student",
        "description": "Student records"
    },
    "options": {
        "draftAndPublish": true
    },
    "pluginOptions": {},
    "attributes": {
        "fullName": {
            "type": "string",
            "required": true
        },
        "tcIdentity": {
            "type": "string",
            "required": true,
            "unique": true,
            "maxLength": 11
        },
        "birthDate": {
            "type": "date"
        },
        "diagnosis": {
            "type": "enumeration",
            "enum": [
                "AUTISM",
                "DYSLEXIA",
                "ADHD",
                "INTELLECTUAL_DISABILITY",
                "HEARING_IMPAIRMENT",
                "PHYSICAL_DISABILITY"
            ]
        },
        "status": {
            "type": "enumeration",
            "enum": [
                "ACTIVE",
                "INACTIVE",
                "GRADUATED",
                "SUSPENDED"
            ],
            "default": "ACTIVE"
        },
        "ramReportEndDate": {
            "type": "date"
        },
        "parentName": {
            "type": "string"
        },
        "parentPhone": {
            "type": "string"
        },
        "avatarUrl": {
            "type": "string"
        },
        "ramReports": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::ram-report.ram-report",
            "mappedBy": "student"
        },
        "bepTargets": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::bep-target.bep-target",
            "mappedBy": "student"
        },
        "educationalModules": {
            "type": "relation",
            "relation": "manyToMany",
            "target": "api::educational-module.educational-module",
            "inversedBy": "students"
        }
    }
}