{
  "kind": "collectionType",
  "collectionName": "appointments",
  "info": {
    "singularName": "appointment",
    "pluralName": "appointments",
    "displayName": "Appointment",
    "description": "Online appointment booking for parent-teacher meetings"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "startTime": {
      "type": "time",
      "required": true
    },
    "endTime": {
      "type": "time",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "confirmed",
        "cancelled",
        "completed"
      ],
      "default": "pending",
      "required": true
    },
    "type": {
      "type": "enumeration",
      "enum": [
        "in-person",
        "online",
        "phone"
      ],
      "default": "in-person"
    },
    "notes": {
      "type": "text"
    },
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student-profile.student-profile"
    },
    "teacher": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::teacher-profile.teacher-profile"
    },
    "requestedBy": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "meetingLink": {
      "type": "string"
    },
    "reminderSent": {
      "type": "boolean",
      "default": false
    }
  }
}