{
    "kind": "collectionType",
    "collectionName": "tenants",
    "info": {
        "singularName": "tenant",
        "pluralName": "tenants",
        "displayName": "Tenant",
        "description": "Multi-tenant organization"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "slug": {
            "type": "string",
            "required": true,
            "unique": true,
            "regex": "^[a-z0-9-]+$"
        },
        "displayName": {
            "type": "string"
        },
        "logo": {
            "type": "media",
            "multiple": false,
            "required": false,
            "allowedTypes": [
                "images"
            ]
        },
        "isActive": {
            "type": "boolean",
            "default": true
        },
        "settings": {
            "type": "json",
            "default": {}
        },
        "subdomain": {
            "type": "string",
            "unique": true
        },
        "users": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "plugin::users-permissions.user",
            "mappedBy": "tenant"
        }
    }
}