{
    "kind": "collectionType",
    "collectionName": "tenants",
    "info": {
        "singularName": "tenant",
        "pluralName": "tenants",
        "displayName": "Tenant",
        "description": "Companies using the ERP system"
    },
    "options": {
        "draftAndPublish": false
    },
    "pluginOptions": {},
    "attributes": {
        "name": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "domain": {
            "type": "string",
            "required": true,
            "unique": true
        },
        "mebbisUsername": {
            "type": "string",
            "private": true
        },
        "mebbisPassword": {
            "type": "string",
            "private": true
        },
        "students": {
            "type": "relation",
            "relation": "oneToMany",
            "target": "api::student-profile.student-profile",
            "mappedBy": "tenant"
        }
    }
}