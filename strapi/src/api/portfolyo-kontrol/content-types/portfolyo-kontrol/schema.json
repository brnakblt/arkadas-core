{
  "kind": "collectionType",
  "collectionName": "portfolyo_kontrol_listeleri",
  "info": {
    "singularName": "portfolyo-kontrol",
    "pluralName": "portfolyo-kontrol-listeleri",
    "displayName": "Portfolyo Kontrol Listesi (Ek-6)",
    "description": "Öğrenci portfolyosu değerlendirme kontrol listesi"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "student": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::student-profile.student-profile"
    },
    "academicYear": {
      "type": "string",
      "required": true
    },
    "semester": {
      "type": "enumeration",
      "enum": [
        "guz",
        "bahar"
      ],
      "required": true
    },
    "evaluationDate": {
      "type": "date",
      "required": true
    },
    "evaluator": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "portfolyoItems": {
      "type": "json",
      "default": {
        "bepKopyasi": false,
        "kabaDegerlendirme": false,
        "kontrolListesi": false,
        "performansKayitlari": false,
        "calismaOrnekleri": false,
        "fotograflar": false,
        "videolar": false,
        "veliGorusleri": false,
        "ogrenciOzdegerlendirme": false,
        "digerMateryaller": false
      }
    },
    "bepCopyExists": {
      "type": "boolean",
      "default": false
    },
    "assessmentFormsExist": {
      "type": "boolean",
      "default": false
    },
    "workSamplesCount": {
      "type": "integer",
      "default": 0
    },
    "photoCount": {
      "type": "integer",
      "default": 0
    },
    "videoCount": {
      "type": "integer",
      "default": 0
    },
    "parentFeedbackExists": {
      "type": "boolean",
      "default": false
    },
    "selfEvaluationExists": {
      "type": "boolean",
      "default": false
    },
    "overallCompleteness": {
      "type": "enumeration",
      "enum": [
        "eksik",
        "kismen_tam",
        "tam",
        "mukemmel"
      ]
    },
    "notes": {
      "type": "text"
    },
    "attachments": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    }
  }
}